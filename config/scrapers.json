{
  "version": 1,
  "defaults": {
    "model": "anthropic/claude-3.5-sonnet",
    "enabled": true
  },
  "sources": [
    {
      "name": "github_trending",
      "display_name": "GitHub Trending",
      "source_type": "api",
      "category": "code",
      "enabled": true,
      "url": "https://api.github.com/search/repositories",
      "method": "GET",
      "headers": {
        "Accept": "application/vnd.github.v3+json",
        "User-Agent": "DailyInfo-Bot"
      },
      "auth_env": "GITHUB_TOKEN",
      "params": {
        "q": "created:>{two_days_ago} stars:>20",
        "sort": "stars",
        "order": "desc",
        "per_page": 25
      },
      "extract": {
        "items_path": "items",
        "fields": {
          "name": "full_name",
          "description": "description",
          "stars": "stargazers_count",
          "language": "language",
          "url": "html_url"
        }
      },
      "max_items": 25
    },
    {
      "name": "huggingface_models",
      "display_name": "HuggingFace Trending Models",
      "source_type": "api",
      "category": "code",
      "enabled": true,
      "url": "https://huggingface.co/api/models",
      "method": "GET",
      "params": {
        "sort": "trendingScore",
        "direction": "-1",
        "limit": 20
      },
      "extract": {
        "fields": {
          "name": "id",
          "task": "pipeline_tag",
          "likes": "likes",
          "downloads": "downloads"
        }
      },
      "max_items": 20
    },
    {
      "name": "huggingface_datasets",
      "display_name": "HuggingFace Trending Datasets",
      "source_type": "api",
      "category": "code",
      "enabled": true,
      "url": "https://huggingface.co/api/datasets",
      "method": "GET",
      "params": {
        "sort": "trendingScore",
        "direction": "-1",
        "limit": 10
      },
      "extract": {
        "fields": {
          "name": "id",
          "likes": "likes",
          "downloads": "downloads"
        }
      },
      "max_items": 10
    },
    {
      "name": "huggingface_spaces",
      "display_name": "HuggingFace Trending Spaces",
      "source_type": "api",
      "category": "code",
      "enabled": true,
      "url": "https://huggingface.co/api/spaces",
      "method": "GET",
      "params": {
        "sort": "trendingScore",
        "direction": "-1",
        "limit": 10
      },
      "extract": {
        "fields": {
          "name": "id",
          "likes": "likes",
          "sdk": "sdk"
        }
      },
      "max_items": 10
    },
    {
      "name": "dlut_news_academic",
      "display_name": "大连理工大学 - 学术科研新闻",
      "source_type": "scrape",
      "category": "resource",
      "enabled": true,
      "url": "http://news.dlut.edu.cn/xsky.htm",
      "base_url": "http://news.dlut.edu.cn/",
      "selector": "ul.nylistn > li.bg-mask",
      "fields": {
        "title": "text",
        "url": "a[href]",
        "date": "time"
      },
      "max_items": 10
    },
    {
      "name": "dlut_sche",
      "display_name": "大连理工大学 - 建设工程学院",
      "source_type": "scrape",
      "category": "resource",
      "enabled": true,
      "url": "http://sche.dlut.edu.cn",
      "base_url": "http://sche.dlut.edu.cn/",
      "selector": "div.sublist ul > li",
      "fields": {
        "title": "a",
        "url": "a[href]",
        "date": "span.date"
      },
      "max_items": 10
    },
    {
      "name": "dlut_futureschool",
      "display_name": "大连理工大学 - 未来技术学院",
      "source_type": "scrape",
      "category": "resource",
      "enabled": true,
      "url": "http://futureschool.dlut.edu.cn",
      "base_url": "http://futureschool.dlut.edu.cn/",
      "selector": "div.list ul > li",
      "fields": {
        "title": "div.name",
        "url": "a[href]",
        "date": "div.time"
      },
      "max_items": 10
    },
    {
      "name": "dlut_scidep",
      "display_name": "大连理工大学 - 科学技术研究院",
      "source_type": "scrape",
      "category": "resource",
      "enabled": true,
      "url": "http://scidep.dlut.edu.cn/zytz.htm",
      "base_url": "http://scidep.dlut.edu.cn/",
      "selector": "ul.tz-ul > li",
      "fields": {
        "title": "div.tz-ul-tt",
        "url": "a[href]",
        "date": "div.tz-ul-date"
      },
      "max_items": 10
    }
  ],
  "prompt_templates": {
    "code_trending": "你是一位资深技术编辑。请为以下技术趋势项目各生成一句话中文摘要（突出核心功能/亮点）：\n\n{items}\n\n返回格式：按原始分组，每个项目一行，格式为：\n**项目名** — 一句话描述\n\n要求：简洁精准，突出技术价值和创新点。",
    "university_news": "你是一位高校信息助理。请对以下大连理工大学相关网站的最新通知/新闻进行简洁汇总：\n\n{items}\n\n返回格式：每条一行，格式为：\n**[日期] 标题** — 一句话说明（如无摘要则概括标题含义）\n\n要求：突出与科研、项目申报、学术活动相关的重要信息；如有申报截止日期请着重标注。"
  },
  "slack_channels": {
    "code": "#code",
    "resource": "#resource"
  }
}
