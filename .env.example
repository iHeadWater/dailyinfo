# OpenClaw 配置
OPENCLAW_API_KEY=your_openclaw_api_key_here

# n8n 配置
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_password_here

# OpenRouter API Key (用于 Python 脚本 / n8n 工作流调用 Claude/GPT 等模型)
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# --- Jina 爬虫配置 ---

# DeepSeek API Key (用于 n8n 工作流调用 DeepSeek 模型)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Jina Reader API Key (可选，用于提高抓取频率)
# 获取地址: https://jina.ai/reader/
JINA_API_KEY=your_jina_key_here

# Discord Bot Token (用于推送简报到 Discord 频道)
# 获取地址: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# FreshRSS 账号配置 (用于 setup.sh 自动创建账号 + run_pipelines.py 读取 DB)
# FRESHRSS_USER: 你的 FreshRSS 用户名，每人不同（留空则自动使用系统用户名 $USER）
FRESHRSS_USER=
FRESHRSS_PASSWORD=freshrss123