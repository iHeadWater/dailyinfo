# DailyInfo Configuration
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (required)
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Discord Bot Token (required for push)
# Get at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# FreshRSS username (optional, defaults to system $USER)
FRESHRSS_USER=
FRESHRSS_PASSWORD=freshrss123

# Workspace root (optional)
# - Leave empty for default: ~/Google Drive/dailyinfo/workspace
# - Set to a custom path if needed
WORKSPACE_ROOT=